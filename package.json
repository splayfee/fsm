{
  "name": "@edium/fsm",
  "version": "3.0.1",
  "description": "Simple finite state machine framework that can be used with client or server.",
  "repository": {
    "type": "git",
    "url": "https://github.com/splayfee/fsm.git"
  },
  "bugs": {
    "url": "https://github.com/splayfee/fsm/issues",
    "email": "david@edium.com"
  },
  "docs": {
    "url": "https://github.com/splayfee/fsm/blob/master/README.md"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --out-dir dist --clean --tsconfig tsconfig.tsup.json",
    "fix": "pnpm lint --fix && pnpm format",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "finite state machine",
    "fsm",
    "workflow",
    "game engine",
    "state",
    "transitions",
    "triggers",
    "actions"
  ],
  "homepage": "https://github.com/splayfee/fsm",
  "author": "David LaTour <david@edium.com>",
  "dependencies": {
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
